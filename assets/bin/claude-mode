#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-code"
MODE_FILE="$CONFIG_DIR/mode"
ENV_FILE="$CONFIG_DIR/mode.env"
API_KEY_FILE="$CONFIG_DIR/api.key"

mkdir -p "$CONFIG_DIR"

usage() {
  cat <<'USAGE'
Usage:
  claude-mode
  claude-mode status
  claude-mode subscription
  claude-mode api [API_KEY] [BASE_URL]
  claude-mode local [BASE_URL] [AUTH_TOKEN] [API_KEY]

Modes:
  subscription  Use Claude Code subscription/OAuth from ~/.claude/.credentials.json
  api           Use direct Anthropic API billing (API key required)
  local         Use local-compatible endpoint (default: Ollama at http://localhost:11434)
USAGE
}

show_status() {
  local mode="subscription"
  if [[ -f "$MODE_FILE" ]]; then
    mode="$(cat "$MODE_FILE")"
  fi

  echo "Current Claude mode: $mode"
  if [[ -f "$ENV_FILE" ]]; then
    echo "Env file: $ENV_FILE"
  else
    echo "Env file not generated yet. Run: claude-mode subscription"
  fi
}

show_help() {
  show_status
  echo
  usage
  cat <<'HELP'

Examples:
  claude-mode subscription
  claude-mode api sk-ant-api03-...                      # Anthropic API billing
  claude-mode api sk-ant-api03-... https://api.anthropic.com
  claude-mode local                                     # Ollama defaults
  claude-mode local http://localhost:4000 sk-local-token unused

Notes:
  - Changes persist via: ~/.config/claude-code/mode.env
  - Apply immediately in current shell:
      source ~/.config/claude-code/mode.env
  - Or open a new terminal before launching Claude Code.
HELP
}

shell_quote() {
  local value="${1:-}"
  printf "%q" "$value"
}

write_header() {
  cat > "$ENV_FILE" <<EOF_HEADER
# Generated by claude-mode on $(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF_HEADER
}

set_subscription_mode() {
  write_header
  cat >> "$ENV_FILE" <<'EOF_SUB'
unset ANTHROPIC_API_KEY
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_BASE_URL
unset LITELLM_MASTER_KEY
EOF_SUB
  echo "subscription" > "$MODE_FILE"
}

set_api_mode() {
  local api_key="${1:-}"
  local base_url="${2:-https://api.anthropic.com}"

  if [[ -z "$api_key" && -f "$API_KEY_FILE" ]]; then
    api_key="$(cat "$API_KEY_FILE")"
  fi
  if [[ -z "$api_key" ]]; then
    api_key="${ANTHROPIC_API_KEY:-}"
  fi
  if [[ -z "$api_key" ]]; then
    printf "Enter Anthropic API key: " >&2
    read -rs api_key
    echo >&2
  fi
  if [[ -z "$api_key" ]]; then
    echo "No API key provided." >&2
    exit 1
  fi

  printf "%s" "$api_key" > "$API_KEY_FILE"
  chmod 600 "$API_KEY_FILE"

  local q_api_key q_base_url
  q_api_key="$(shell_quote "$api_key")"
  q_base_url="$(shell_quote "$base_url")"

  write_header
  cat >> "$ENV_FILE" <<EOF_API
export ANTHROPIC_API_KEY=$q_api_key
unset ANTHROPIC_AUTH_TOKEN
export ANTHROPIC_BASE_URL=$q_base_url
unset LITELLM_MASTER_KEY
EOF_API
  echo "api" > "$MODE_FILE"
}

set_local_mode() {
  local base_url="${1:-http://localhost:11434}"
  local auth_token="${2:-ollama}"
  local api_key="${3:-unused}"

  local q_api_key q_auth_token q_base_url
  q_api_key="$(shell_quote "$api_key")"
  q_auth_token="$(shell_quote "$auth_token")"
  q_base_url="$(shell_quote "$base_url")"

  write_header
  cat >> "$ENV_FILE" <<EOF_LOCAL
export ANTHROPIC_API_KEY=$q_api_key
export ANTHROPIC_AUTH_TOKEN=$q_auth_token
export ANTHROPIC_BASE_URL=$q_base_url
unset LITELLM_MASTER_KEY
EOF_LOCAL
  echo "local" > "$MODE_FILE"
}

cmd="${1:-help}"
case "$cmd" in
  status)
    show_status
    ;;
  subscription)
    set_subscription_mode
    echo "Claude mode set to subscription."
    echo "Run: source \"$ENV_FILE\"  (or open a new terminal)"
    ;;
  api)
    set_api_mode "${2:-}" "${3:-}"
    echo "Claude mode set to api."
    echo "Run: source \"$ENV_FILE\"  (or open a new terminal)"
    ;;
  local)
    set_local_mode "${2:-}" "${3:-}" "${4:-}"
    echo "Claude mode set to local."
    echo "Run: source \"$ENV_FILE\"  (or open a new terminal)"
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
